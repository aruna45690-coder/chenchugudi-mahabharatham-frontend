// This is your Prisma schema file for the Chenchugudi Festival Platform
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// Gallery photos/videos uploaded by admin
model GalleryImage {
  id          Int      @id @default(autoincrement())
  title       String
  imageUrl    String   // stores Cloudinary URL (image or video thumbnail)
  mediaType   String   @default("IMAGE") // IMAGE, VIDEO, YOUTUBE
  videoUrl    String?  // Original video URL or YouTube URL
  publicId    String?  // Cloudinary asset ID for deletion
  uploadedBy  String
  eventDate   DateTime
  eventName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Announcements to be shown in the News section
model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  titleTe   String?  // Telugu translation
  content   String
  contentTe String?  // Telugu translation
  date      DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Track unique page views on a daily basis by IP
model UserVisit {
  id        Int      @id @default(autoincrement())
  ipAddress String
  visitDate String   // Format: YYYY-MM-DD for simple day-by-day grouping
  createdAt DateTime @default(now())

  @@unique([ipAddress, visitDate]) // Unique constraint: one visit log per IP per day
}

// Track user website feedback (likes/dislikes)
model Feedback {
  id        Int      @id @default(autoincrement())
  isLike    Boolean  // true for Like, false for Dislike
  ipAddress String   @unique // Only one feedback entry allowed per unique IP
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Global site settings (e.g., Live Stream configuration)
model SiteSetting {
  id            Int      @id @default(1)
  liveStreamUrl      String?  // YouTube video ID or URL
  liveStreamPlatform String   @default("youtube") // youtube, facebook, twitch, instagram
  isLiveActive       Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}


